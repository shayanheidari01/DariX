import graph

print("=== Graph Module Tests ===")

// Build: 0 -> 1, 0 -> 2, 1 -> 2, 2 -> 3
var g = graph.from_edges([[0, 1], [0, 2], [1, 2], [2, 3]])
print("to_string:", graph.to_string(g))
print("vertices:", graph.vertices(g))
print("edges:", graph.edges(g))
print("vertex_count:", graph.vertex_count(g))
print("edge_count:", graph.edge_count(g))
print("is_empty:", graph.is_empty(graph.new()))

// Neighbors and degree
print("neighbors of 0:", graph.neighbors(g, 0))
print("degree of 0:", graph.degree(g, 0))
print("in_degree of 2:", graph.in_degree(g, 2))

// Membership
print("has_vertex 0:", graph.has_vertex(g, 0))
print("has_vertex 99:", graph.has_vertex(g, 99))
print("has_edge 0->1:", graph.has_edge(g, 0, 1))
print("has_edge 1->0:", graph.has_edge(g, 1, 0))

// Add/Remove
var g2 = graph.add_vertex(g, 4)
print("add_vertex:", graph.vertex_count(g2))
var g3 = graph.add_edge(g, 3, 0)
print("add_edge 3->0:", graph.has_edge(g3, 3, 0))
var g4 = graph.add_undirected_edge(graph.new(), 1, 2)
print("undirected:", graph.edges(g4))
var g5 = graph.remove_edge(g, 0, 1)
print("remove_edge:", graph.has_edge(g5, 0, 1))
var g6 = graph.remove_vertex(g, 3)
print("remove_vertex:", graph.vertex_count(g6))

// Traversals
print("bfs from 0:", graph.bfs(g, 0))
print("dfs from 0:", graph.dfs(g, 0))

// Shortest path
print("shortest 0->3:", graph.shortest_path(g, 0, 3))
print("shortest 0->99:", graph.shortest_path(g, 0, 99))
print("has_path 0->3:", graph.has_path(g, 0, 3))
print("has_path 0->99:", graph.has_path(g, 0, 99))

// Connected (treat as undirected for test)
var ug = graph.new()
graph.add_undirected_edge(ug, 0, 1)
graph.add_undirected_edge(ug, 1, 2)
graph.add_undirected_edge(ug, 2, 3)
print("is_connected:", graph.is_connected(ug))
var ug2 = graph.new()
graph.add_vertex(ug2, 0)
graph.add_vertex(ug2, 1)
print("not connected:", graph.is_connected(ug2))

// Topological sort (DAG)
var dag = graph.from_edges([[0, 1], [0, 2], [1, 3], [2, 3]])
print("topo_sort:", graph.topological_sort(dag))

// Transpose
var tg = graph.transpose(dag)
print("transpose:", graph.to_string(tg))

// Clone
var cg = graph.clone(g)
print("clone equals:", graph.equals(g, cg))

print("\nALL GRAPH TESTS COMPLETE")
