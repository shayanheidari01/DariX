import math

print("sqrt(16):", math.sqrt(16))
print("sqrt(2):", math.sqrt(2))
print("pow(2,10):", math.pow(2, 10))
print("sin(0):", math.sin(0))
print("cos(0):", math.cos(0))
print("pi:", math.pi())
print("e:", math.e())
print("ceil(3.2):", math.ceil(3.2))
print("floor(3.8):", math.floor(3.8))
print("round(3.5):", math.round(3.5))
print("abs(-7):", math.abs(-7))
print("random():", math.random())

import string

print("upper:", string.upper("hello"))
print("lower:", string.lower("HELLO"))
print("trim:", string.trim("  hello  "))
print("split:", string.split("a,b,c", ","))
print("join:", string.join(["x","y","z"], "-"))
print("replace:", string.replace("hello world", "world", "DariX"))
print("contains:", string.contains("hello", "ell"))
print("starts:", string.starts("hello", "hel"))
print("ends:", string.ends("hello", "llo"))
print("index:", string.index("hello", "ell"))
print("last_index:", string.last_index("hello", "l"))
print("repeat:", string.repeat("ab", 3))
print("reverse:", string.reverse("abc"))
print("is_alpha:", string.is_alpha("hello"))
print("is_digit:", string.is_digit("123"))
print("is_space:", string.is_space("   "))
print("ALL TESTS COMPLETE")
