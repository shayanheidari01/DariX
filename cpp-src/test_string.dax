import string

print("=== String Module Tests ===")

// Original functions
var s = "Hello, World!"
print("upper:", string.upper(s))
print("lower:", string.lower(s))
print("trim:", string.trim("  hello  "))
print("split:", string.split("a,b,c", ","))
print("join:", string.join(["x","y","z"], "-"))
print("replace:", string.replace("hello world", "world", "DariX"))
print("contains:", string.contains("hello", "ell"))
print("starts:", string.starts("hello", "hel"))
print("ends:", string.ends("hello", "llo"))
print("index:", string.index("hello", "ell"))
print("last_index:", string.last_index("hello", "l"))
print("repeat:", string.repeat("ab", 3))
print("reverse:", string.reverse("abc"))
print("is_alpha:", string.is_alpha("hello"))
print("is_digit:", string.is_digit("123"))
print("is_space:", string.is_space("   "))

// New functions
print("\n--- New Functions ---")
print("pad_left:", string.pad_left("42", 5, "0"))
print("pad_right:", string.pad_right("hi", 5, "."))
print("slice:", string.slice("hello world", 6, 11))
print("slice negative:", string.slice("hello", -3))
print("count:", string.count("banana", "a"))
print("char_at:", string.char_at("hello", 1))
print("to_title:", string.to_title("hello world"))
print("chars:", string.chars("abc"))
print("words:", string.words("hello beautiful world"))
print("lines:", string.lines("line1\nline2\nline3"))
print("truncate:", string.truncate("very long string here", 10))
print("truncate custom:", string.truncate("abcdefghij", 7, "..."))
print("center:", string.center("hi", 6, "*"))
print("replace_first:", string.replace_first("aabbcc", "bb", "XX"))
print("is_empty:", string.is_empty(""))
print("is_empty nonempty:", string.is_empty("x"))
print("starts_with:", string.starts_with("hello", "hel"))
print("ends_with:", string.ends_with("hello", "llo"))
print("to_int:", string.to_int("42"))
print("to_float:", string.to_float("3.14"))
print("is_number:", string.is_number("3.14"))
print("is_number text:", string.is_number("abc"))

print("\nALL STRING TESTS COMPLETE")
